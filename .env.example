# --- LLM (Google Gemini via ADK) ---
GOOGLE_API_KEY=
# Use direct Gemini API (False) or Vertex AI (True). Local dev = False
GOOGLE_GENAI_USE_VERTEXAI=False

# --- Optional: Vertex AI deployment (留白，本地不用填) ---
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=us-central1

# --- data.gov.sg (CEA agent verification, used by Risk Agent) ---
# 在 https://guide.data.gov.sg 注册后申请，免费
# 不填也能跑（匿名访问），但有更严的限流
DATAGOVSG_API_KEY=

# --- Runtime ---
LOG_LEVEL=INFO
